# Postgres local (docker-compose)
DATABASE_URL=postgresql://pos:pos_dev@localhost:5432/pos_tercos_dev?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-access
JWT_REFRESH_SECRET=change-me-in-prod-refresh

# API
API_PORT=3001
API_HOST=0.0.0.0

# CORS (dev: allow all next.js apps)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# Anthropic (IA facturas + auto-pedido) — primary
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI (fallback IA) — opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM provider preference: 'anthropic' | 'openai'
# Si solo hay una key configurada, esa se usa sin importar este valor.
LLM_PROVIDER=anthropic

# Mapbox / Google Maps (geocoding + autocomplete + maps, FASE 7+)
MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# WhatsApp adapter (en dev: 'mock')
WHATSAPP_PROVIDER=mock

# Storage adapter (en dev: 'local', en prod: 'r2')
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./tmp/uploads

# Restaurant geo (lat/lng del local — para validación 3km)
RESTAURANT_LAT=4.6533
RESTAURANT_LNG=-74.0836
RESTAURANT_DELIVERY_RADIUS_KM=3
