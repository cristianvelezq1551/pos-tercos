generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// AUTH + USERS (FASE 1)
// =====================================================================

enum UserRole {
  CAJERO
  COCINERO
  REPARTIDOR
  ADMIN_OPERATIVO
  DUENO
  TRABAJADOR
}

enum RepartidorAvailability {
  DISPONIBLE
  OCUPADO
  OFFLINE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  fullName      String   @map("full_name")
  phone         String?
  role          UserRole
  mustChangePwd Boolean  @default(true) @map("must_change_pwd")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  availability RepartidorAvailability?
  lastActiveAt DateTime?               @map("last_active_at")

  refreshTokens      RefreshToken[]
  inventoryMovements InventoryMovement[]
  auditLogs          AuditLog[]
  invoicesUploaded   Invoice[]           @relation("InvoiceUploadedBy")
  invoicesConfirmed  Invoice[]           @relation("InvoiceConfirmedBy")

  @@index([role, active])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// =====================================================================
// CATÁLOGO + RECETAS (FASE 2)
// =====================================================================

model Product {
  id               String   @id @default(uuid())
  name             String
  description      String?
  basePrice        Decimal  @map("base_price") @db.Decimal(12, 2)
  category         String?
  imageUrl         String?  @map("image_url")
  modifiersEnabled Boolean  @default(false) @map("modifiers_enabled")
  isCombo          Boolean  @default(false) @map("is_combo")
  comboPrice       Decimal? @map("combo_price") @db.Decimal(12, 2)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Direct-resale fields (FASE 4 refactor):
  // si directResale=true → el producto es comprado y vendido tal cual
  //   (botellas, snacks empaquetados). Tiene stock propio en
  //   inventory_movements y descuenta directo al venderse.
  // si directResale=false → producto elaborado, sin stock, descuenta
  //   insumos via expandRecipe al venderse.
  directResale     Boolean   @default(false) @map("direct_resale")
  unitPurchase     String?   @map("unit_purchase")
  unitStock        String?   @map("unit_stock")
  conversionFactor Decimal?  @map("conversion_factor") @db.Decimal(14, 6)
  thresholdMin     Decimal   @default(0) @map("threshold_min") @db.Decimal(14, 4)

  // Última info de costo (auto-actualizado al confirmar facturas).
  // basePrice (más arriba) sigue siendo el PRECIO DE VENTA al cliente.
  // lastUnitCost es el COSTO de compra (en unit_purchase del producto).
  lastUnitCost     Decimal?  @map("last_unit_cost") @db.Decimal(14, 4)
  lastUnitCostDate DateTime? @map("last_unit_cost_date")

  sizes      ProductSize[]
  modifiers  ProductModifier[]
  recipeEdges RecipeEdge[]    @relation("ProductRecipe")

  // If is_combo=true → list of components
  comboComponents ComboComponent[] @relation("ComboParent")
  // Reverse: products listed as components inside a combo
  partOfCombos    ComboComponent[] @relation("ComboChild")

  // Direct-resale stockable side
  movements         InventoryMovement[]
  invoiceItems      InvoiceItem[]
  supplierResaleHistory SupplierProduct[] @relation("SupplierProductResale")

  @@index([category, isActive])
  @@index([isActive])
  @@index([directResale, isActive])
  @@map("products")
}

model ProductSize {
  id            String  @id @default(uuid())
  productId     String  @map("product_id")
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  priceModifier Decimal @map("price_modifier") @db.Decimal(12, 2) @default(0)
  sortOrder     Int     @default(0) @map("sort_order")

  @@index([productId])
  @@map("product_sizes")
}

model ProductModifier {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  priceDelta  Decimal @map("price_delta") @db.Decimal(12, 2) @default(0)
  recipeDelta Json    @map("recipe_delta") @default("{}")

  @@index([productId])
  @@map("product_modifiers")
}

model ComboComponent {
  id        String  @id @default(uuid())
  comboId   String  @map("combo_id")
  combo     Product @relation("ComboParent", fields: [comboId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation("ComboChild", fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int     @default(1)

  @@index([comboId])
  @@index([productId])
  @@map("combo_components")
}

model Subproduct {
  id        String   @id @default(uuid())
  name      String
  yield     Decimal  @db.Decimal(10, 4)
  unit      String   @default("unidad")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Recipes that PRODUCE this subproduct
  recipeEdges RecipeEdge[] @relation("SubproductRecipe")
  // Recipes where this subproduct IS CONSUMED
  consumedAs  RecipeEdge[] @relation("SubproductChild")

  @@index([isActive])
  @@map("subproducts")
}

model Ingredient {
  id               String   @id @default(uuid())
  name             String
  unitPurchase     String   @map("unit_purchase")
  unitRecipe       String   @map("unit_recipe")
  conversionFactor Decimal  @map("conversion_factor") @db.Decimal(14, 6)
  thresholdMin     Decimal  @map("threshold_min") @db.Decimal(14, 4) @default(0)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  consumedAs       RecipeEdge[]        @relation("IngredientChild")
  movements        InventoryMovement[]
  supplierProducts SupplierProduct[]
  invoiceItems     InvoiceItem[]

  @@index([isActive])
  @@map("ingredients")
}

model RecipeEdge {
  id String @id @default(uuid())

  // Parent: exactly one of (parentProductId, parentSubproductId) is non-null
  // Enforced by CHECK constraint added in migration SQL.
  parentProductId    String?     @map("parent_product_id")
  parentProduct      Product?    @relation("ProductRecipe", fields: [parentProductId], references: [id], onDelete: Cascade)
  parentSubproductId String?     @map("parent_subproduct_id")
  parentSubproduct   Subproduct? @relation("SubproductRecipe", fields: [parentSubproductId], references: [id], onDelete: Cascade)

  // Child: exactly one of (childIngredientId, childSubproductId) is non-null
  childIngredientId String?     @map("child_ingredient_id")
  childIngredient   Ingredient? @relation("IngredientChild", fields: [childIngredientId], references: [id], onDelete: Restrict)
  childSubproductId String?     @map("child_subproduct_id")
  childSubproduct   Subproduct? @relation("SubproductChild", fields: [childSubproductId], references: [id], onDelete: Restrict)

  quantityNeta Decimal @map("quantity_neta") @db.Decimal(14, 4)
  mermaPct     Decimal @map("merma_pct") @db.Decimal(5, 4) @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([parentProductId])
  @@index([parentSubproductId])
  @@index([childIngredientId])
  @@index([childSubproductId])
  @@map("recipe_edges")
}

// =====================================================================
// INVENTARIO + AUDIT (FASE 3)
// =====================================================================

enum InventoryMovementType {
  PURCHASE          // entrada por factura confirmada (FASE 4)
  SALE              // salida por venta (FASE 5; computado vía expandRecipe)
  MANUAL_ADJUSTMENT // ajuste manual por admin/dueño
  WASTE             // pérdida registrada
  INITIAL           // stock inicial al cargar el sistema
}

/// Discriminador para entidades stock-trackeables.
enum StockableType {
  INGREDIENT
  PRODUCT
}

model InventoryMovement {
  id             String                @id @default(uuid())
  entityType     StockableType         @map("entity_type")
  ingredientId   String?               @map("ingredient_id")
  ingredient     Ingredient?           @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  productId      String?               @map("product_id")
  product        Product?              @relation(fields: [productId], references: [id], onDelete: Restrict)
  delta          Decimal               @db.Decimal(14, 4)
  type           InventoryMovementType
  sourceType     String?               @map("source_type")
  sourceId       String?               @map("source_id")
  userId         String?               @map("user_id")
  user           User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes          String?
  idempotencyKey String?               @unique @map("idempotency_key")
  createdAt      DateTime              @default(now()) @map("created_at")

  @@index([ingredientId, createdAt(sort: Desc)])
  @@index([productId, createdAt(sort: Desc)])
  @@index([entityType, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("inventory_movements")
}

/// Insert-only audit trail for sensitive actions.
/// `action` is a free-form string validated against AuditActionEnum
/// in @pos-tercos/types (string column for forward-compat without
/// requiring DB migrations to add new actions).
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_log")
}

// =====================================================================
// PROVEEDORES + FACTURAS (FASE 4)
// =====================================================================

model Supplier {
  id        String   @id @default(uuid())
  nit       String   @unique
  name      String
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products SupplierProduct[]
  invoices Invoice[]

  @@index([isActive])
  @@map("suppliers")
}

/// Catálogo histórico de costos por (proveedor, item). Polimórfico igual
/// que inventory_movements: el item asociado puede ser un Insumo o un
/// Producto direct-resale.
///
/// `last_unit_price` está en la unidad de COMPRA del item (kg, caja,
/// pack-12). Para obtener costo por unidad de stock, dividir por
/// conversion_factor del item.
model SupplierProduct {
  id               String         @id @default(uuid())
  supplierId       String         @map("supplier_id")
  supplier         Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  entityType       StockableType  @map("entity_type")
  ingredientId     String?        @map("ingredient_id")
  ingredient       Ingredient?    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  productId        String?        @map("product_id")
  product          Product?       @relation("SupplierProductResale", fields: [productId], references: [id], onDelete: Cascade)
  lastUnitPrice    Decimal?       @map("last_unit_price") @db.Decimal(14, 4)
  lastPurchaseDate DateTime?      @map("last_purchase_date")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([supplierId, ingredientId])
  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([ingredientId])
  @@index([productId])
  @@map("supplier_products")
}

enum InvoiceStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

model Invoice {
  id               String        @id @default(uuid())
  supplierId       String?       @map("supplier_id")
  supplier         Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoiceNumber    String?       @map("invoice_number")
  total            Decimal?      @db.Decimal(14, 2)
  iva              Decimal?      @db.Decimal(14, 2)
  photoStorageKey  String?       @map("photo_storage_key")
  aiExtractionJson Json?         @map("ai_extraction_json")
  aiModelUsed      String?       @map("ai_model_used")
  status           InvoiceStatus @default(PENDING_REVIEW)
  uploadedById     String?       @map("uploaded_by_id")
  uploadedBy       User?         @relation("InvoiceUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  confirmedById    String?       @map("confirmed_by_id")
  confirmedBy      User?         @relation("InvoiceConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt      DateTime?     @map("confirmed_at")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  items InvoiceItem[]

  @@index([status, createdAt(sort: Desc)])
  @@index([supplierId, createdAt(sort: Desc)])
  @@map("invoices")
}

model InvoiceItem {
  id             String         @id @default(uuid())
  invoiceId      String         @map("invoice_id")
  invoice        Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // Polimórfico: el item de la factura puede asociarse a un Insumo o
  // a un Producto direct-resale. Un item sin asociar tiene los 3 NULL.
  entityType     StockableType? @map("entity_type")
  ingredientId   String?        @map("ingredient_id")
  ingredient     Ingredient?    @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  productId      String?        @map("product_id")
  product        Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  descriptionRaw String         @map("description_raw")
  quantity       Decimal        @db.Decimal(14, 4)
  unit           String
  unitPrice      Decimal        @map("unit_price") @db.Decimal(14, 4)
  total          Decimal        @db.Decimal(14, 2)
  sortOrder      Int            @default(0) @map("sort_order")

  @@index([invoiceId])
  @@index([ingredientId])
  @@index([productId])
  @@map("invoice_items")
}
